# === Railway 部署环境变量 (必须设置) ===

# 数据库 - Railway PostgreSQL 插件会自动注入 DATABASE_URL
# 如果使用 SQLite + Volume，保持 file:./dev.db 即可
DATABASE_URL="file:./dev.db"

# PUBG API 配置 (必须设置)
PUBG_API_KEY="你的PUBG_API_KEY"
PUBG_API_BASE="https://api.pubg.com/shards/steam"

# 环境
NODE_ENV=production

# CORS - 允许的前端域名，多个用逗号分隔
CORS_ORIGIN="https://你的前端.pages.dev"

# 端口 - Railway 会自动设置 PORT 环境变量
PORT=3001
